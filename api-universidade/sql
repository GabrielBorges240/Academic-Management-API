-- 1. Liste todos os professores cadastrados no banco de dados
SELECT
    professor_id,
    nome,
    email
FROM Professor;

-- 2. Liste todos os alunos ordenados pelo nome
SELECT
    aluno_id,
    nome,
    email,
    data_nascimento
FROM Aluno
ORDER BY nome ASC;

-- 3. Liste os nomes das disciplinas ordenadas da que possui
--    mais alunos matriculados para a que possui menos
SELECT
    d.nome                AS disciplina,
    COUNT(m.matricula_id) AS total_alunos
FROM Disciplina d
LEFT JOIN Turma     t ON t.disciplina_id = d.disciplina_id
LEFT JOIN Matricula m ON m.turma_id      = t.turma_id
GROUP BY d.disciplina_id, d.nome
ORDER BY total_alunos DESC;