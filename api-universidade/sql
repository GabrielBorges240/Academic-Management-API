-- ================================================
-- Banco de Dados: Sistema de Universidade
-- ================================================

-- CRIAÇÃO DAS TABELAS (DDL)

CREATE TABLE Departamento (
    departamento_id INT AUTO_INCREMENT PRIMARY KEY,
    nome            VARCHAR(100) NOT NULL
);

CREATE TABLE Curso (
    curso_id        INT AUTO_INCREMENT PRIMARY KEY,
    nome            VARCHAR(100) NOT NULL,
    departamento_id INT NOT NULL,
    CONSTRAINT fk_curso_departamento
        FOREIGN KEY (departamento_id) REFERENCES Departamento(departamento_id)
);

CREATE TABLE Professor (
    professor_id    INT AUTO_INCREMENT PRIMARY KEY,
    nome            VARCHAR(100) NOT NULL,
    email           VARCHAR(100) NOT NULL UNIQUE,
    departamento_id INT NOT NULL,
    CONSTRAINT fk_professor_departamento
        FOREIGN KEY (departamento_id) REFERENCES Departamento(departamento_id)
);

CREATE TABLE Aluno (
    aluno_id        INT AUTO_INCREMENT PRIMARY KEY,
    nome            VARCHAR(100) NOT NULL,
    email           VARCHAR(100) NOT NULL UNIQUE,
    data_nascimento DATE         NOT NULL,
    curso_id        INT NOT NULL,
    CONSTRAINT fk_aluno_curso
        FOREIGN KEY (curso_id) REFERENCES Curso(curso_id)
);

CREATE TABLE Disciplina (
    disciplina_id   INT AUTO_INCREMENT PRIMARY KEY,
    nome            VARCHAR(100) NOT NULL,
    carga_horaria   INT          NOT NULL,
    curso_id        INT NOT NULL,
    CONSTRAINT fk_disciplina_curso
        FOREIGN KEY (curso_id) REFERENCES Curso(curso_id)
);

CREATE TABLE Turma (
    turma_id        INT AUTO_INCREMENT PRIMARY KEY,
    semestre        CHAR(6)      NOT NULL,  -- ex: 2024.1
    disciplina_id   INT NOT NULL,
    professor_id    INT NOT NULL,
    CONSTRAINT fk_turma_disciplina
        FOREIGN KEY (disciplina_id) REFERENCES Disciplina(disciplina_id),
    CONSTRAINT fk_turma_professor
        FOREIGN KEY (professor_id)  REFERENCES Professor(professor_id)
);

CREATE TABLE Matricula (
    matricula_id    INT AUTO_INCREMENT PRIMARY KEY,
    data_matricula  DATE NOT NULL,
    aluno_id        INT  NOT NULL,
    turma_id        INT  NOT NULL,
    CONSTRAINT fk_matricula_aluno
        FOREIGN KEY (aluno_id)  REFERENCES Aluno(aluno_id),
    CONSTRAINT fk_matricula_turma
        FOREIGN KEY (turma_id)  REFERENCES Turma(turma_id),
    CONSTRAINT uq_aluno_turma UNIQUE (aluno_id, turma_id)
);

